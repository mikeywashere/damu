<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             x:Class="DamYou.Views.TasksView"
             x:DataType="vm:TasksViewModel"
             Title="Running Tasks"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="40">

        <!-- Header: running + queued counts -->
        <HorizontalStackLayout Grid.Row="0" Spacing="24" Margin="0,0,0,24">
            <Label FontSize="20"
                   FontAttributes="Bold">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="🔄 Running: " />
                        <Span Text="{Binding TotalRunning}" FontAttributes="Bold" />
                        <Span Text="     ⏳ Queued: " />
                        <Span Text="{Binding TotalQueued}" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </HorizontalStackLayout>

        <!-- Task list -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Tasks}">
            <CollectionView.EmptyView>
                <Label Text="No active tasks."
                       FontSize="15"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Opacity="0.5"
                       Margin="0,40,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PipelineTaskDisplayItem">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          Padding="12,10"
                          Margin="0,2">
                        <Grid.Background>
                            <SolidColorBrush Color="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                        </Grid.Background>

                        <!-- Task name + status -->
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding TaskName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding StatusText}"
                                   FontSize="12"
                                   Opacity="0.7" />
                            <Label FontSize="11"
                                   Opacity="0.5"
                                   IsVisible="{Binding PhotoId, Converter={StaticResource IntToBoolConverter}}">
                                <Label.Text>
                                    <Binding Path="PhotoId" StringFormat="Photo #{0}" />
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>

                        <!-- Created time -->
                        <Label Grid.Column="2"
                               Text="{Binding CreatedAt, StringFormat='{0:HH:mm:ss}'}"
                               FontSize="12"
                               Opacity="0.5"
                               VerticalOptions="Center"
                               Margin="8,0,0,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer: refresh button -->
        <HorizontalStackLayout Grid.Row="2"
                               HorizontalOptions="End"
                               Margin="0,16,0,0">
            <Button Text="Refresh"
                    Command="{Binding LoadTasksCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" />
        </HorizontalStackLayout>

    </Grid>
</ContentPage>
