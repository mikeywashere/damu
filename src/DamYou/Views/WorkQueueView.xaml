<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             xmlns:entities="clr-namespace:DamYou.Data.Entities;assembly=DamYou.Data"
             x:Class="DamYou.Views.WorkQueueView"
             x:DataType="vm:WorkQueueViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
             Loaded="OnPageLoaded">

    <Grid RowDefinitions="Auto,*" Padding="12">

        <!-- Header: queue counts -->
        <HorizontalStackLayout Grid.Row="0" Spacing="24" Margin="0,0,0,12">
            <Label FontSize="13" Opacity="0.7">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="📁 Folders: " />
                        <Span Text="{Binding QueuedFolders.Count}" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label FontSize="13" Opacity="0.7">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="🖼️ Files: " />
                        <Span Text="{Binding QueuedFiles.Count}" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </HorizontalStackLayout>

        <!-- Queue content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!-- Empty state -->
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Margin="0,40,0,0"
                                     IsVisible="{Binding IsEmpty}">
                    <Label Text="✓"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="No work queued"
                           FontSize="16"
                           HorizontalOptions="Center"
                           FontAttributes="Bold" />
                    <Label Text="Both queues are clear"
                           FontSize="13"
                           HorizontalOptions="Center"
                           Opacity="0.6" />
                </VerticalStackLayout>

                <!-- Folder Queue section -->
                <VerticalStackLayout Spacing="6" IsVisible="{Binding HasFolders}">
                    <Label Text="Folder Queue"
                           FontSize="12"
                           FontAttributes="Bold"
                           Opacity="0.5"
                           Margin="4,0" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding QueuedFolders}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="entities:QueuedFolder">
                                <Grid Padding="12,10"
                                      Margin="0,2"
                                      ColumnDefinitions="*,Auto"
                                      BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding FolderPath, Converter={StaticResource TruncateMiddleConverter}}"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               ToolTipProperties.Text="{Binding FolderPath}" />
                                        <Label Text="{Binding Status}"
                                               FontSize="11"
                                               Opacity="0.6" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding AddedAt, StringFormat='{0:HH:mm:ss}'}"
                                           FontSize="11"
                                           Opacity="0.5"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- File Queue section -->
                <VerticalStackLayout Spacing="6" IsVisible="{Binding HasFiles}">
                    <Label Text="File Queue"
                           FontSize="12"
                           FontAttributes="Bold"
                           Opacity="0.5"
                           Margin="4,0" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding QueuedFiles}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="entities:QueuedFile">
                                <Grid Padding="12,10"
                                      Margin="0,2"
                                      ColumnDefinitions="*,Auto"
                                      BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding FilePath, Converter={StaticResource TruncateMiddleConverter}}"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               ToolTipProperties.Text="{Binding FilePath}" />
                                        <Label Text="{Binding Status}"
                                               FontSize="11"
                                               Opacity="0.6" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding AddedAt, StringFormat='{0:HH:mm:ss}'}"
                                           FontSize="11"
                                           Opacity="0.5"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
