<?xml version="1.0" encoding="utf-8" ?>
<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:local="clr-namespace:DamYou.ViewModels"
      x:Class="DamYou.Views.StatusBar"
      x:DataType="local:ProcessingStateViewModel"
      RowDefinitions="Auto,Auto"
      ColumnDefinitions="Auto,*,Auto,Auto,Auto"
      ColumnSpacing="8"
      RowSpacing="4"
      Padding="12,8"
      BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}"
      x:Name="Root">

    <!-- Row 0: Processing indicator + status + progress + action buttons -->

    <!-- Processing Indicator (Spinner when busy, check when idle) -->
    <ActivityIndicator Grid.Row="0" Grid.Column="0"
                       IsRunning="{Binding IsProcessing}"
                       IsVisible="{Binding IsProcessing}"
                       Color="{AppThemeBinding Light=#0078D4, Dark=#60CDFF}"
                       Scale="0.8"
                       VerticalOptions="Center" />

    <Label Grid.Row="0" Grid.Column="0"
           Text="✓"
           FontSize="16"
           TextColor="{AppThemeBinding Light=#107C10, Dark=#1AA260}"
           IsVisible="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"
           VerticalOptions="Center"
           FontAttributes="Bold" />

    <!-- Status Text and Progress -->
    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2" VerticalOptions="Center">
        <Label Text="{Binding StatusText}"
               FontSize="13"
               FontAttributes="Bold"
               HorizontalOptions="Start" />

        <Label Text="{Binding ProgressText}"
               FontSize="11"
               Opacity="0.7"
               HorizontalOptions="Start"
               IsVisible="{Binding IsProcessing}" />
    </VerticalStackLayout>

    <!-- Right-aligned progress detail -->
    <Label Grid.Row="0" Grid.Column="2"
           Text="{Binding ProgressText}"
           FontSize="11"
           Opacity="0.6"
           HorizontalOptions="End"
           VerticalOptions="Center"
           IsVisible="{Binding IsProcessing}" />

    <!-- "Folders" Button -->
    <Button Grid.Row="0" Grid.Column="3"
            Text="Folders"
            FontSize="12"
            Padding="8,4"
            CornerRadius="4"
            BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#3C3C3C}"
            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
            Clicked="OnFoldersClicked"
            VerticalOptions="Center" />

    <!-- "Start Processing" Button -->
    <Button Grid.Row="0" Grid.Column="4"
            Text="Start Processing"
            FontSize="12"
            Padding="8,4"
            CornerRadius="4"
            Style="{StaticResource PrimaryButtonStyle}"
            Command="{Binding StartProcessingCommand}"
            VerticalOptions="Center" />

    <!-- Row 1: Queue counts + current item path with tooltip -->
    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                           Spacing="16"
                           VerticalOptions="Center">

        <!-- Folder queue count badge -->
        <Label Text="{Binding FolderQueueCount, StringFormat='📁 {0} folders'}"
               FontSize="11"
               Opacity="0.8" />

        <!-- File queue count badge -->
        <Label Text="{Binding FileQueueCount, StringFormat='🖼️ {0} files'}"
               FontSize="11"
               Opacity="0.8" />

        <!-- Active queue mode -->
        <Label Text="{Binding ActiveQueue, StringFormat='[{0}]'}"
               FontSize="11"
               TextColor="{AppThemeBinding Light=#0078D4, Dark=#60CDFF}"
               IsVisible="{Binding ActiveQueue, Converter={StaticResource StringNotEmptyConverter}}" />

        <!-- Current item: truncated middle with full-path tooltip on hover -->
        <Label Text="{Binding CurrentItemFull, Converter={StaticResource TruncateMiddleConverter}}"
               FontSize="11"
               Opacity="0.7"
               ToolTipProperties.Text="{Binding CurrentItemFull}"
               IsVisible="{Binding CurrentItemFull, Converter={StaticResource StringNotEmptyConverter}}"
               LineBreakMode="NoWrap" />

    </HorizontalStackLayout>

</Grid>
