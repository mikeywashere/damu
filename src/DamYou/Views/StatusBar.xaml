<?xml version="1.0" encoding="utf-8" ?>
<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:local="clr-namespace:DamYou.ViewModels"
      x:Class="DamYou.Views.StatusBar"
      x:DataType="local:ProcessingStateViewModel"
      ColumnDefinitions="Auto,*,Auto,Auto,Auto"
      ColumnSpacing="8"
      Padding="12"
      BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}"
      x:Name="Root">

    <!-- Processing Indicator (Spinner when busy, icon when idle) -->
    <ActivityIndicator Grid.Column="0"
                       IsRunning="{Binding IsProcessing}"
                       IsVisible="{Binding IsProcessing}"
                       Color="{AppThemeBinding Light=#0078D4, Dark=#60CDFF}"
                       Scale="0.8"
                       VerticalOptions="Center" />

    <Label Grid.Column="0"
           Text="✓"
           FontSize="16"
           TextColor="{AppThemeBinding Light=#107C10, Dark=#1AA260}"
           IsVisible="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"
           VerticalOptions="Center"
           FontAttributes="Bold" />

    <!-- Status Text and Progress -->
    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
        <Label Text="{Binding StatusText}"
               FontSize="13"
               FontAttributes="Bold"
               HorizontalOptions="Start" />
        
        <Label Text="{Binding ProgressText}"
               FontSize="11"
               Opacity="0.7"
               HorizontalOptions="Start"
               IsVisible="{Binding IsProcessing}" />
    </VerticalStackLayout>

    <!-- Right-aligned detail (can add more info here) -->
    <Label Grid.Column="2"
           Text="{Binding ProgressText}"
           FontSize="11"
           Opacity="0.6"
           HorizontalOptions="End"
           VerticalOptions="Center"
           IsVisible="{Binding IsProcessing}" />

    <!-- "Folders" Button — opens modal to manage indexed folders -->
    <Button Grid.Column="3"
            Text="Folders"
            FontSize="12"
            Padding="8,4"
            CornerRadius="4"
            BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#3C3C3C}"
            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
            Clicked="OnFoldersClicked"
            VerticalOptions="Center" />

    <!-- "Start Processing" Button — manually trigger the photo analysis pipeline -->
    <Button Grid.Column="4"
            Text="Start Processing"
            FontSize="12"
            Padding="8,4"
            CornerRadius="4"
            Style="{StaticResource PrimaryButtonStyle}"
            Command="{Binding StartProcessingCommand}"
            VerticalOptions="Center" />
</Grid>
