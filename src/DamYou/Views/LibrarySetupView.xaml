<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             x:Class="DamYou.Views.LibrarySetupView"
             x:DataType="vm:LibrarySetupViewModel"
             Title="Set Up Your Photo Library"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="40">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,32">
            <Label Text="📸 dam-you"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Tell us where your photos are."
                   FontSize="16"
                   HorizontalOptions="Center"
                   Opacity="0.7" />
            <Label Text="You can add multiple folders. Subfolders are included automatically."
                   FontSize="13"
                   HorizontalOptions="Center"
                   Opacity="0.5" />
        </VerticalStackLayout>

        <!-- Folder list -->
        <VerticalStackLayout Grid.Row="1" Spacing="0">
            <!-- Empty state -->
            <VerticalStackLayout IsVisible="{Binding SelectedFolders.Count, Converter={StaticResource IntToBoolConverter}, ConverterParameter=invert}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12"
                                 Margin="0,40,0,0">
                <Label Text="No folders added yet."
                       FontSize="15"
                       HorizontalOptions="Center"
                       Opacity="0.5" />
                <Label Text="Click 'Add Folder' to get started."
                       FontSize="13"
                       HorizontalOptions="Center"
                       Opacity="0.4" />
            </VerticalStackLayout>

            <!-- Folder items -->
            <CollectionView ItemsSource="{Binding SelectedFolders}"
                            IsVisible="{Binding SelectedFolders.Count, Converter={StaticResource IntToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="12,10"
                              Margin="0,2">
                            <Grid.Background>
                                <SolidColorBrush Color="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                            </Grid.Background>
                            <Label Grid.Column="0"
                                   Text="{Binding .}"
                                   VerticalOptions="Center"
                                   FontSize="14"
                                   LineBreakMode="MiddleTruncation" />
                            <Button Grid.Column="1"
                                    Text="✕"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LibrarySetupViewModel}}, Path=RemoveFolderCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="36"
                                    HeightRequest="36" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Action area: buttons or import progress -->
        <Grid Grid.Row="2" Margin="0,24,0,0">

            <!-- Normal buttons (hidden while importing) -->
            <HorizontalStackLayout HorizontalOptions="End"
                                   Spacing="12"
                                   IsVisible="{Binding IsImporting, Converter={StaticResource InvertBoolConverter}}">
                <Button Text="Add Folder"
                        Command="{Binding AddFolderCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Text="Start Indexing →"
                        Command="{Binding CompleteSetupCommand}"
                        IsEnabled="{Binding CanComplete}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Import progress (visible while scanning) -->
            <VerticalStackLayout IsVisible="{Binding IsImporting}" Spacing="6">
                <Label Text="Scanning photos…"
                       FontSize="14"
                       HorizontalOptions="Center" />
                <ProgressBar Progress="{Binding ImportProgressFraction}"
                             HeightRequest="8" />
                <Label Text="{Binding ImportProgressText}"
                       FontSize="12"
                       HorizontalOptions="Center"
                       Opacity="0.7" />
                <Label Text="{Binding ImportCurrentFile}"
                       FontSize="11"
                       HorizontalOptions="Center"
                       Opacity="0.5"
                       LineBreakMode="MiddleTruncation" />
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
