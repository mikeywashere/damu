<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             x:Class="DamYou.Views.RunningTasksView"
             x:DataType="vm:RunningTasksViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
             Loaded="OnPageLoaded">

    <Grid RowDefinitions="Auto,*" Padding="12">

        <!-- Header: counts and status -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,12">
            <Label Text="⏳ Running Tasks"
                   FontSize="24"
                   FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="24">
                <Label FontSize="13" Opacity="0.7">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Running: " />
                            <Span Text="{Binding TotalRunning}" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="13" Opacity="0.7">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Queued: " />
                            <Span Text="{Binding TotalQueued}" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Task list -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Tasks}">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="12"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                    <Label Text="✓"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="No active tasks"
                           FontSize="16"
                           HorizontalOptions="Center"
                           FontAttributes="Bold" />
                    <Label Text="Your queue is clear"
                           FontSize="13"
                           HorizontalOptions="Center"
                           Opacity="0.6" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PipelineTaskDisplayItem">
                    <VerticalStackLayout Padding="12,10"
                                        Margin="0,4"
                                        Spacing="6">
                        <Grid.Background>
                            <SolidColorBrush Color="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                        </Grid.Background>
                        
                        <!-- Task header: name, status, time -->
                        <Grid ColumnDefinitions="*,Auto" Padding="4,0">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding TaskName}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding StatusText}"
                                       FontSize="11"
                                       Opacity="0.7" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="{Binding CreatedAt, StringFormat='{0:HH:mm:ss}'}"
                                   FontSize="11"
                                   Opacity="0.5"
                                   VerticalOptions="Center" />
                        </Grid>
                        
                        <!-- Progress section (only if task has progress data) -->
                        <VerticalStackLayout Spacing="4" 
                                            IsVisible="{Binding TotalItems, Converter={StaticResource IntToBoolConverter}}"
                                            Padding="4,0">
                            <!-- Current item name (if available) -->
                            <Label Text="{Binding CurrentItemName, StringFormat='📷 {0}'}"
                                   FontSize="12"
                                   LineBreakMode="TailTruncation"
                                   IsVisible="{Binding CurrentItemName, Converter={StaticResource StringNotEmptyConverter}}"
                                   Opacity="0.85" />
                            
                            <!-- Progress bar -->
                            <Grid ColumnDefinitions="*,Auto" Spacing="8" VerticalOptions="Center">
                                <ProgressBar Grid.Column="0"
                                            Progress="{Binding ProgressPercentage, Converter={StaticResource PercentageToProgressConverter}}"
                                            HeightRequest="6"
                                            CornerRadius="3"
                                            VerticalOptions="Center">
                                    <ProgressBar.ProgressColor>
                                        <AppThemeBinding Light="#007AFF" Dark="#0A84FF" />
                                    </ProgressBar.ProgressColor>
                                </ProgressBar>
                                <!-- Progress text -->
                                <Label Grid.Column="1"
                                       Text="{Binding ProgressPercentage, StringFormat='{0:F0}%'}"
                                       FontSize="11"
                                       Opacity="0.7"
                                       WidthRequest="35"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            
                            <!-- Item count -->
                            <Label Text="{Binding ProgressText}"
                                   FontSize="10"
                                   Opacity="0.6" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
