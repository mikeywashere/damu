<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             xmlns:local="clr-namespace:DamYou"
             x:Class="DamYou.Views.GalleryView"
             x:DataType="vm:GalleryViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
             Loaded="OnPageLoaded">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Padding="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,0,0,12">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="📷 Your Library"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Start" />
            </VerticalStackLayout>
        </Grid>

        <!-- Scan progress (visible only while scanning) -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsScanning}"
                             Spacing="6"
                             Margin="0,0,0,12"
                             Padding="12"
                             BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1E1E1E}">
            <Label Text="Scanning library…"
                   FontSize="14"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="{Binding ScanProgressText}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   Opacity="0.7" />
            <Label Text="{Binding ScanCurrentFolder}"
                   FontSize="11"
                   HorizontalOptions="Center"
                   Opacity="0.5"
                   LineBreakMode="MiddleTruncation" />
            <ActivityIndicator IsRunning="{Binding IsScanning}"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Search Bar and Filters -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto"
              Margin="0,0,0,12">
            
            <!-- Search Bar -->
            <SearchBar Grid.Row="0"
                       Grid.Column="0"
                       Placeholder="Search by filename or folder…"
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding SearchTextChangedCommand}"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

            <!-- Toggle Properties Panel Button -->
            <Button Grid.Row="0"
                    Grid.Column="1"
                    Text="⚙️"
                    Command="{Binding TogglePropertiesPanelCommand}"
                    Padding="8"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="4"
                    FontSize="18" />

            <!-- Properties Panel (collapsible) -->
            <VerticalStackLayout Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                IsVisible="{Binding IsPropertiesPanelVisible}"
                                Padding="12"
                                Margin="0,8,0,0"
                                BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}"
                                Spacing="8">
                <Label Text="Filters"
                       FontSize="12"
                       FontAttributes="Bold" />
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                    <Label Grid.Row="0" Grid.Column="0" Text="Processing Status:" FontSize="12" />
                    <Picker Grid.Row="0" Grid.Column="1" SelectedIndexChanged="OnProcessingStatusChanged">
                        <Picker.Items>
                            <x:String>All</x:String>
                            <x:String>Processed</x:String>
                            <x:String>Unprocessed</x:String>
                        </Picker.Items>
                    </Picker>
                    <Label Grid.Row="1" Grid.Column="0" Text="Sort By:" FontSize="12" />
                    <Picker Grid.Row="1" Grid.Column="1" SelectedIndexChanged="OnSortChanged">
                        <Picker.Items>
                            <x:String>Newest First</x:String>
                            <x:String>Oldest First</x:String>
                            <x:String>By Filename</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>
            </VerticalStackLayout>
        </Grid>

        <!-- Grid View -->
        <Grid Grid.Row="4">
            <!-- Empty State -->
            <VerticalStackLayout HorizontalOptions="Center"
                                VerticalOptions="Center"
                                IsVisible="{Binding GridPhotos.Count, Converter={StaticResource IntToBoolConverter}, ConverterParameter=invert}">
                <Label Text="📷"
                       FontSize="64"
                       HorizontalOptions="Center" />
                <Label Text="No photos yet"
                       FontSize="18"
                       HorizontalOptions="Center"
                       Opacity="0.6"
                       Margin="0,12,0,0" />
                <Label Text="Rescan your library to load photos."
                       FontSize="12"
                       HorizontalOptions="Center"
                       Opacity="0.5" />
            </VerticalStackLayout>

            <!-- Photo Grid -->
            <ScrollView x:Name="GridScrollView"
                       IsVisible="{Binding GridPhotos.Count, Converter={StaticResource IntToBoolConverter}}">
                <FlexLayout x:Name="PhotoGrid"
                           Wrap="Wrap"
                           JustifyContent="Start"
                           AlignItems="Start"
                           Padding="0" />
            </ScrollView>
        </Grid>

        <!-- Loading Indicator -->
        <VerticalStackLayout Grid.Row="4"
                            IsVisible="{Binding IsLoadingMore}"
                            HorizontalOptions="Center"
                            VerticalOptions="End"
                            Margin="0,0,0,24">
            <ActivityIndicator IsRunning="True" />
            <Label Text="Loading more photos…" FontSize="12" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Footer: action buttons + stats -->
        <Grid Grid.Row="5" Margin="0,12,0,0" ColumnDefinitions="*,Auto">

            <!-- Photo count and queue depth -->
            <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                <Label FontSize="12" Opacity="0.7">
                    <Label.Text>
                        <Binding Path="PhotoCount" StringFormat="Photos: {0}" />
                    </Label.Text>
                </Label>
            </HorizontalStackLayout>

            <!-- Action buttons -->
            <HorizontalStackLayout Grid.Column="1" Spacing="12">
                <Button Text="🔄 Rescan"
                        Command="{Binding RescanLibraryCommand}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InvertBoolConverter}}"
                        Padding="8"
                        FontSize="12"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </HorizontalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
