<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             x:Class="DamYou.Views.FoldersView"
             x:DataType="vm:FoldersViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
             Loaded="OnPageLoaded">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <Label Text="📁 Manage Photo Folders"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Start" />
            <Label Text="Add or remove folders. Use 🔄 to queue a folder for scanning."
                   FontSize="13"
                   HorizontalOptions="Start"
                   Opacity="0.6" />
        </VerticalStackLayout>

        <!-- Folder list with drag-drop overlay -->
        <Grid Grid.Row="1" RowDefinitions="*">
            <VerticalStackLayout Grid.Row="0" Spacing="0">
            <!-- Empty state -->
            <VerticalStackLayout IsVisible="{Binding SelectedFolders.Count, Converter={StaticResource IntToBoolConverter}, ConverterParameter=invert}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12"
                                 Margin="0,40,0,0">
                <Label Text="No folders added yet."
                       FontSize="15"
                       HorizontalOptions="Center"
                       Opacity="0.5" />
                <Label Text="Click 'Add Folder' to get started."
                       FontSize="13"
                       HorizontalOptions="Center"
                       Opacity="0.4" />
            </VerticalStackLayout>

            <!-- Folder items with checkbox -->
            <CollectionView ItemsSource="{Binding SelectedFolders}"
                            IsVisible="{Binding SelectedFolders.Count, Converter={StaticResource IntToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                              Padding="12,10"
                              Margin="0,2">
                            <Grid.Background>
                                <SolidColorBrush Color="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                            </Grid.Background>
                            
                            <!-- Checkbox for re-index -->
                            <CheckBox Grid.Column="0"
                                      VerticalOptions="Center"
                                      Margin="0,0,8,0" />
                            
                            <!-- Folder path -->
                            <Label Grid.Column="1"
                                   Text="{Binding .}"
                                   VerticalOptions="Center"
                                   FontSize="14"
                                   LineBreakMode="MiddleTruncation" />
                            
                            <!-- Scan Now button -->
                            <Button Grid.Column="2"
                                    Text="🔄"
                                    BackgroundColor="Transparent"
                                    TextColor="#1976D2"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FoldersViewModel}}, Path=ScanFolderCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="48"
                                    HeightRequest="48" />

                            <!-- Remove button -->
                            <Button Grid.Column="3"
                                    Text="🗑️"
                                    BackgroundColor="Transparent"
                                    TextColor="#E64A19"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FoldersViewModel}}, Path=RemoveFolderCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="48"
                                    HeightRequest="48" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            </VerticalStackLayout>

            <!-- Drag-drop overlay (shows when idle and list is empty) -->
            <Border Grid.Row="0"
                    x:Name="DragDropOverlay"
                    Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                    StrokeThickness="2"
                    StrokeDashPattern="5,5"
                    BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#1A1A1A}"
                    Opacity="0.7"
                    CornerRadius="8"
                    IsVisible="{Binding SelectedFolders.Count, Converter={StaticResource IntToBoolConverter}, ConverterParameter=invert}"
                    Padding="24"
                    AllowDrop="True"
                    DragOver="OnDragOver"
                    Drop="OnDrop">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="📂"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="Drag and drop folders here to add them"
                           FontSize="15"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           FontAttributes="Bold" />
                    <Label Text="or click 'Add Folder' below"
                           FontSize="12"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Opacity="0.6" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Action buttons -->
        <HorizontalStackLayout Grid.Row="2"
                               Margin="0,24,0,0"
                               Spacing="12"
                               HorizontalOptions="End">
            <Button Text="Add Folder"
                    Command="{Binding AddFolderCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                    Style="{StaticResource SecondaryButtonStyle}" />
        </HorizontalStackLayout>

    </Grid>
</ContentPage>
