<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DamYou.ViewModels"
             xmlns:views="clr-namespace:DamYou.Views"
             x:Class="DamYou.Views.TabbedView"
             x:DataType="vm:TabbedViewModel"
             Title="DAMu"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
             Loaded="OnPageLoaded">

    <TabView SelectedIndex="{Binding SelectedTabIndex}"
             TabBarBackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
             TabBarTextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
             TabBarUnselectedTextColor="{AppThemeBinding Light=#999999, Dark=#666666}"
             Padding="0">

        <!-- Gallery Tab -->
        <TabViewItem Title="🖼️ Gallery"
                     IsSelected="{Binding GalleryTabSelected}">
            <views:GalleryView />
        </TabViewItem>

        <!-- Folders Tab -->
        <TabViewItem Title="📁 Folders"
                     IsSelected="{Binding FoldersTabSelected}">
            <views:FoldersView />
        </TabViewItem>

        <!-- Running Tasks Tab -->
        <TabViewItem Title="⏳ Tasks"
                     IsSelected="{Binding TasksTabSelected}">
            <views:RunningTasksView />
        </TabViewItem>

    </TabView>

</ContentPage>
